# Server Configuration
PORT=5000
NODE_ENV=production

# Database Connection (PostgreSQL with PgBouncer)
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:6543/postgres?pgbouncer=true
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# JWT Secret Keys
JWT_SECRET=your-minimum-32-char-random-access-secret
JWT_REFRESH_SECRET=your-minimum-32-char-random-refresh-secret

# AI Integration
GEMINI_API_KEY=your-gemini-api-key

# CORS Configuration
CLIENT_URL=https://your-ecopulse-app.vercel.app

# Google OAuth2 Credentials (Optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
